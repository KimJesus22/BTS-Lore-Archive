---
// GlossaryForm.astro
---
<div class="glass-card p-6">
  <h3 class="font-serif text-xl text-on-surface mb-4">Añadir Término</h3>
  <form id="glossary-form" class="space-y-4">
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-sm text-on-surface-variant mb-1">Término</label>
        <input type="text" name="term" required class="w-full bg-surface-dim border border-border rounded px-3 py-2 text-on-surface" />
      </div>
      <div>
        <label class="block text-sm text-on-surface-variant mb-1">Categoría</label>
        <input type="text" name="category" placeholder="Ej: Concepto, Lugar..." class="w-full bg-surface-dim border border-border rounded px-3 py-2 text-on-surface" />
      </div>
    </div>
    <div>
      <label class="block text-sm text-on-surface-variant mb-1">Definición</label>
      <textarea name="definition" required rows="2" class="w-full bg-surface-dim border border-border rounded px-3 py-2 text-on-surface"></textarea>
    </div>
    <button type="submit" class="bg-surface-bright border border-border text-on-surface px-4 py-2 rounded font-semibold w-full hover:bg-surface-variant transition-colors">
      Guardar Término
    </button>
    <p id="gl-msg" class="text-sm text-center hidden mt-2"></p>
  </form>
</div>

<script>
  import { createGlossaryTerm } from '../../services/glossary.service';

  const form = document.getElementById('glossary-form') as HTMLFormElement;
  const msg = document.getElementById('gl-msg');

  if (form && msg) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const term = formData.get('term') as string;
      
      const newTerm = {
        id: crypto.randomUUID(),
        term,
        slug: term.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)+/g, ''),
        category: formData.get('category') as string,
        definition: formData.get('definition') as string
      };

      try {
        msg.textContent = 'Guardando...';
        msg.className = 'text-sm text-center mt-2 text-on-surface-variant block';
        
        await createGlossaryTerm(newTerm);
        
        msg.textContent = '¡Término guardado!';
        msg.className = 'text-sm text-center mt-2 text-primary-light block';
        form.reset();
      } catch (err) {
        console.error(err);
        msg.textContent = 'Error al guardar. Revisa la consola.';
        msg.className = 'text-sm text-center mt-2 text-red-400 block';
      }
    });
  }
</script>
