---
interface Props {
  variant?: 'default' | 'compact';
}

const { variant = 'default' } = Astro.props;
const isCompact = variant === 'compact';
---

<article class={`glass-card overflow-hidden p-5 ${isCompact ? 'space-y-4' : 'space-y-5 md:p-6'}`} aria-hidden="true">
  <div class="flex items-center gap-3">
    <span class="block h-10 w-10 rounded-full bg-white/10 skeleton-line"></span>
    <div class="flex-1 space-y-2">
      <span class="skeleton-line w-1/3"></span>
      <span class="skeleton-line w-2/3"></span>
    </div>
  </div>
  <div class="space-y-3">
    <span class="skeleton-line w-full"></span>
    <span class="skeleton-line w-11/12"></span>
    {!isCompact && <span class="skeleton-line w-2/3"></span>}
  </div>
</article>
