---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
}

const siteName = 'BTS Lore Archive';
const defaultTitle = 'BTS Lore Archive';
const defaultDescription = 'Archivo en español para explorar eras, teorías, cronología, símbolos y conceptos del universo narrativo de BTS.';
const defaultImage = '/og-default.svg';

const {
  title = defaultTitle,
  description = defaultDescription,
  image = defaultImage,
  canonical,
} = Astro.props;

const pageTitle = title === defaultTitle ? defaultTitle : `${title} | ${siteName}`;
const canonicalUrl = new URL(canonical ?? Astro.url.pathname, Astro.url.origin).toString();
const imageUrl = new URL(image, Astro.url.origin).toString();
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="index, follow" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="es_MX" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600&family=Playfair+Display:wght@600;700&family=Space+Grotesk:wght@600;700&display=swap" rel="stylesheet">
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <slot name="head" />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    {/* Global Settings Manager — runs on every page */}
    <script>
      const OLD_SPOILER_KEY = 'bts-lore-spoiler-safe';
      const SETTINGS_KEY = 'bts-lore-settings';

      interface LoreSettings {
        spoilerSafe: boolean;
        textSize: 'small' | 'normal' | 'large';
        density: 'comfortable' | 'compact';
        animations: 'enabled' | 'reduced';
      }

      const defaultSettings: LoreSettings = {
        spoilerSafe: false,
        textSize: 'normal',
        density: 'comfortable',
        animations: 'enabled',
      };

      // Expose type and global function to the window for other scripts to use
      declare global {
        interface Window {
          updateLoreSettings: (partial: Partial<LoreSettings>) => void;
        }
      }

      function getSettings(): LoreSettings {
        try {
          // Migration from old spoiler key
          const oldSpoiler = localStorage.getItem(OLD_SPOILER_KEY);
          if (oldSpoiler !== null) {
            const migrated: LoreSettings = { ...defaultSettings, spoilerSafe: oldSpoiler === 'true' };
            localStorage.setItem(SETTINGS_KEY, JSON.stringify(migrated));
            localStorage.removeItem(OLD_SPOILER_KEY);
            return migrated;
          }

          const stored = localStorage.getItem(SETTINGS_KEY);
          if (stored) {
            return { ...defaultSettings, ...JSON.parse(stored) };
          }
        } catch (e) {
          console.warn('Error reading settings from localStorage', e);
        }
        return defaultSettings;
      }

      function applySettings(settings: LoreSettings) {
        const html = document.documentElement;

        // Apply Spoiler classes and data attributes
        document.querySelectorAll<HTMLElement>('.spoiler-block').forEach((block) => {
          block.dataset.spoilerActive = String(settings.spoilerSafe);
        });
        document.querySelectorAll<HTMLElement>('.spoiler-toggle').forEach((toggle) => {
          toggle.dataset.active = String(settings.spoilerSafe);
          toggle.setAttribute('aria-pressed', String(settings.spoilerSafe));
        });

        // Apply Text Size
        html.classList.remove('text-size-small', 'text-size-normal', 'text-size-large');
        html.classList.add(`text-size-${settings.textSize}`);

        // Apply Density
        html.classList.remove('density-comfortable', 'density-compact');
        html.classList.add(`density-${settings.density}`);

        // Apply Animations
        html.classList.remove('animations-enabled', 'animations-reduced');
        html.classList.add(`animations-${settings.animations}`);
      }

      window.updateLoreSettings = (partial: Partial<LoreSettings>) => {
        const current = getSettings();
        const updated = { ...current, ...partial };
        try {
          localStorage.setItem(SETTINGS_KEY, JSON.stringify(updated));
        } catch (e) {
          console.warn('Error saving settings to localStorage', e);
        }
        applySettings(updated);
        
        // Dispatch custom event in case components need to react directly
        window.dispatchEvent(new CustomEvent('lore-settings-updated', { detail: updated }));
      };

      // "Mostrar de todos modos" buttons inside SpoilerBlocks
      document.querySelectorAll<HTMLButtonElement>('.spoiler-reveal-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const block = btn.closest<HTMLElement>('.spoiler-block');
          if (block) {
            block.dataset.spoilerActive = 'false';
          }
        });
      });

      // Initial apply
      const initialSettings = getSettings();
      applySettings(initialSettings);
    </script>
  </body>
</html>
