---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getSymbols } from '../../services/symbols.service';
import type { SymbolItem } from '../../types/symbols';

export async function getStaticPaths() {
  const symbols = await getSymbols();
  return symbols.map((symbol) => {
    return {
      params: { slug: symbol.slug },
      props: { symbol },
    };
  });
}

interface Props {
  symbol: SymbolItem;
}

const { symbol } = Astro.props;
---

<BaseLayout
  title={`${symbol.name} | Símbolos BTS`}
  description={symbol.shortDescription}
  canonical={`/symbols/${symbol.slug}`}
>
  <article class="max-w-[960px] mx-auto px-margin-mobile md:px-margin-desktop py-stack-lg">
    
    <div class="mb-8">
      <a href="/symbols" class="inline-flex items-center text-sm font-semibold text-on-surface-variant hover:text-primary-light transition-colors group">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 mr-2 group-hover:-translate-x-1 transition-transform">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Volver a la Biblioteca
      </a>
    </div>

    {/* Header con Placeholder Visual */}
    <header class="mb-12 relative rounded-3xl overflow-hidden glass-card border-none bg-surface-container-high">
      <div class="h-64 w-full relative bg-gradient-to-br from-surface-dim to-black">
        <div class="absolute inset-0 opacity-30 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-primary via-transparent to-transparent"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="w-24 h-24 rounded-full border border-white/10 bg-white/5 flex items-center justify-center backdrop-blur-md shadow-[0_0_40px_rgba(211,187,255,0.15)]">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12 text-primary-light">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
            </svg>
          </div>
        </div>
      </div>
      
      <div class="p-8 md:p-12 text-center -mt-16 relative z-10">
        <div class="inline-block px-4 py-1.5 rounded-full bg-surface border border-border text-xs font-mono font-bold text-on-surface-variant uppercase tracking-widest mb-4 shadow-lg">
          Símbolo / Motivo
        </div>
        <h1 class="text-4xl md:text-5xl font-serif font-bold text-white mb-4 drop-shadow-md">
          {symbol.name}
        </h1>
        <p class="text-lg text-primary-light font-medium max-w-2xl mx-auto drop-shadow">
          {symbol.shortDescription}
        </p>
      </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      
      {/* Columna Principal */}
      <div class="lg:col-span-2 space-y-12">
        <section class="prose prose-invert prose-p:text-on-surface-variant prose-p:leading-relaxed prose-headings:font-serif prose-headings:text-on-surface max-w-none">
          <h2>Significado y Contexto</h2>
          <p>{symbol.fullDescription}</p>
        </section>

        {/* Tags */}
        <section>
          <h3 class="label-caps mb-4 text-on-surface-variant">Etiquetas</h3>
          <div class="flex flex-wrap gap-2">
            {symbol.tags.map(tag => (
              <span class="px-3 py-1 bg-white/5 border border-white/10 rounded-lg text-sm font-mono text-on-surface hover:border-primary/50 transition-colors cursor-default">
                #{tag}
              </span>
            ))}
          </div>
        </section>
      </div>

      {/* Columna Lateral (Metadatos) */}
      <aside class="space-y-6">
        <div class="glass-card p-6">
          <h3 class="label-caps mb-4 text-on-surface-variant">Metadatos del Símbolo</h3>
          
          <dl class="space-y-4">
            <div>
              <dt class="text-xs font-mono text-on-surface-variant/70 mb-1 uppercase tracking-wider">Primera Aparición</dt>
              <dd class="text-sm font-semibold text-on-surface">{symbol.firstAppearance}</dd>
            </div>
            
            {symbol.relatedMembers.length > 0 && (
              <div>
                <dt class="text-xs font-mono text-on-surface-variant/70 mb-1 uppercase tracking-wider">Miembros Asociados</dt>
                <dd class="text-sm font-semibold text-primary-light">
                  {symbol.relatedMembers.join(', ')}
                </dd>
              </div>
            )}
          </dl>
        </div>

        <div class="glass-card p-6">
          <h3 class="label-caps mb-4 text-on-surface-variant">Conexiones</h3>
          
          {symbol.relatedEras.length > 0 && (
            <div class="mb-4">
              <h4 class="text-sm font-bold text-on-surface mb-2">Eras</h4>
              <ul class="space-y-1">
                {symbol.relatedEras.map(era => (
                  <li>
                    <a href={`/eras/${era}`} class="text-sm text-on-surface-variant hover:text-primary-light transition-colors flex items-center">
                      <span class="w-1.5 h-1.5 rounded-full bg-primary/50 mr-2"></span>
                      {era.replace('era-', '').replace('-', ' ').replace(/\b\w/g, l => l.toUpperCase())}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {symbol.relatedSongs.length > 0 && (
            <div class="mb-4">
              <h4 class="text-sm font-bold text-on-surface mb-2">Canciones</h4>
              <ul class="space-y-1">
                {symbol.relatedSongs.map(song => (
                  <li class="text-sm text-on-surface-variant flex items-center">
                    <span class="w-1.5 h-1.5 rounded-full bg-rose-500/50 mr-2"></span>
                    {song}
                  </li>
                ))}
              </ul>
            </div>
          )}

          {symbol.relatedTheories.length > 0 && (
            <div>
              <h4 class="text-sm font-bold text-on-surface mb-2">Teorías</h4>
              <ul class="space-y-1">
                {symbol.relatedTheories.map(theory => (
                  <li>
                    <a href={`/theories/${theory}`} class="text-sm text-on-surface-variant hover:text-primary-light transition-colors flex items-center">
                      <span class="w-1.5 h-1.5 rounded-full bg-amber-500/50 mr-2"></span>
                      {theory.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </aside>

    </div>
  </article>
</BaseLayout>
