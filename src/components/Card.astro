---
interface Props {
  title: string;
  description: string;
  tag?: string;
  href?: string;
  status?: string;
  variant?: 'default' | 'era';
}

const { title, description, tag, href, status, variant = 'default' } = Astro.props;

const Element = href ? 'a' : 'div';
const extraProps = href ? { href } : {};
const isEra = variant === 'era';
---

<Element {...extraProps} class={`glass-card block group relative overflow-hidden ${isEra ? 'min-h-[280px] p-0 hover:scale-[1.015] hover:shadow-[0_0_32px_rgba(109,40,217,0.18)]' : 'p-6'}`}>
  <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-white/25 to-transparent"></div>
  {isEra && (
    <div class="relative h-24 overflow-hidden border-b border-white/10 bg-surface-dim">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_25%_20%,rgba(211,187,255,0.38),transparent_30%),radial-gradient(circle_at_80%_40%,rgba(233,195,73,0.22),transparent_34%),linear-gradient(135deg,rgba(109,40,217,0.25),rgba(12,15,16,0.7))]"></div>
      <div class="absolute bottom-4 left-6 h-10 w-10 rounded-full border border-primary-light/40 bg-primary/20 shadow-[0_0_28px_rgba(211,187,255,0.32)]"></div>
      <div class="absolute right-6 top-5 h-px w-24 rotate-[-18deg] bg-gradient-to-r from-transparent via-secondary-dim/70 to-transparent"></div>
    </div>
  )}
  
  <div class={isEra ? 'p-6' : ''}>
    <div class="mb-4 flex flex-wrap items-center gap-2">
      {tag && (
        <span class="inline-block px-3 py-1 rounded-full bg-primary/20 text-primary-light label-caps border border-primary/30">
          {tag}
        </span>
      )}
      {status && (
        <span class="inline-block px-3 py-1 rounded-full bg-secondary-dim/10 text-secondary-dim label-caps border border-secondary-dim/25">
          {status}
        </span>
      )}
    </div>
    
    <h3 class="text-xl font-serif font-bold text-on-surface mb-3 group-hover:text-primary-light transition-colors">
      {title}
    </h3>
    
    <p class="text-on-surface-variant text-sm font-sans leading-relaxed">
      {description}
    </p>

    <div class="mt-6 flex items-center text-primary-light opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all">
      <span class="text-sm font-semibold tracking-wide uppercase">Explorar</span>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 ml-1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
      </svg>
    </div>
  </div>
</Element>
