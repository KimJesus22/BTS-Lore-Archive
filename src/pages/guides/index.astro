---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { guides } from '../../data/guides';
import { DIFFICULTY_LABELS } from '../../types/guides';
import type { GuideDifficulty } from '../../types/guides';

const difficultyColors: Record<GuideDifficulty, { badge: string; icon: string }> = {
  'inicial': {
    badge: 'bg-emerald-500/15 text-emerald-400 border-emerald-500/30',
    icon: '●',
  },
  'media': {
    badge: 'bg-amber-500/15 text-amber-400 border-amber-500/30',
    icon: '●●',
  },
  'avanzada': {
    badge: 'bg-red-500/15 text-red-400 border-red-500/30',
    icon: '●●●',
  },
};
---

<BaseLayout
  title="Rutas de lectura"
  description="Guías curadas para explorar el universo narrativo de BTS en orden. Elige tu ruta según tu nivel de conocimiento."
  canonical="/guides"
>
  <div class="max-w-[1280px] mx-auto px-margin-mobile md:px-margin-desktop py-stack-lg">
    <PageHeader
      tag="Rutas de lectura"
      title="Guías de exploración"
      description="No sabes por dónde empezar? Elige una ruta curada para descubrir el lore paso a paso, desde lo esencial hasta las teorías más profundas."
    />

    <!-- Difficulty legend -->
    <div id="guides-legend" class="flex flex-wrap items-center justify-center gap-4 mb-12">
      {(['inicial', 'media', 'avanzada'] as GuideDifficulty[]).map((diff) => (
        <div class="flex items-center gap-2">
          <span class={`inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-mono font-bold uppercase tracking-wider border ${difficultyColors[diff].badge}`}>
            <span class="text-[8px] tracking-[2px]">{difficultyColors[diff].icon}</span>
            {DIFFICULTY_LABELS[diff]}
          </span>
        </div>
      ))}
    </div>

    <!-- Guides grid -->
    <div id="guides-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {guides.map((guide, index) => (
        <a
          href={`/guides/${guide.slug}`}
          class="guide-card glass-card group relative overflow-hidden flex flex-col"
          id={`guide-card-${guide.slug}`}
          style={`animation-delay: ${index * 0.08}s`}
        >
          {/* Top decorative glow */}
          <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-primary/40 via-primary-light/20 to-transparent"></div>

          {/* Decorative number */}
          <div class="absolute top-4 right-5 font-serif text-[72px] font-bold leading-none text-white/[0.03] select-none pointer-events-none">
            {String(index + 1).padStart(2, '0')}
          </div>

          <div class="p-6 flex flex-col flex-1">
            {/* Badges */}
            <div class="flex flex-wrap items-center gap-2 mb-4">
              <span class={`inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[11px] font-mono font-bold uppercase tracking-wider border ${difficultyColors[guide.difficulty].badge}`}>
                <span class="text-[8px] tracking-[2px]">{difficultyColors[guide.difficulty].icon}</span>
                {DIFFICULTY_LABELS[guide.difficulty]}
              </span>
              <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[11px] font-mono font-bold uppercase tracking-wider border border-white/10 bg-white/5 text-on-surface-variant">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3 h-3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                {guide.estimatedTime}
              </span>
            </div>

            {/* Title */}
            <h2 class="text-xl font-serif font-bold text-on-surface mb-3 group-hover:text-primary-light transition-colors">
              {guide.title}
            </h2>

            {/* Description */}
            <p class="text-sm text-on-surface-variant leading-relaxed mb-5 flex-1">
              {guide.description}
            </p>

            {/* Steps preview */}
            <div class="border-t border-border/50 pt-4 mb-4">
              <p class="label-caps text-on-surface-variant/60 mb-3">
                {guide.steps.length} pasos
              </p>
              <div class="flex items-center gap-1.5">
                {guide.steps.map((_, i) => (
                  <div class={`h-1 flex-1 rounded-full ${i === 0 ? 'bg-primary/50' : 'bg-white/10'}`}></div>
                ))}
              </div>
            </div>

            {/* Tags */}
            <div class="flex flex-wrap gap-1.5">
              {guide.tags.map((tag) => (
                <span class="label-caps rounded-full border border-primary/20 bg-primary/10 px-2.5 py-0.5 text-primary-light/80 text-[10px]">
                  {tag}
                </span>
              ))}
            </div>

            {/* CTA arrow */}
            <div class="mt-5 flex items-center text-primary-light opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300">
              <span class="text-sm font-semibold tracking-wide uppercase">Comenzar ruta</span>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 ml-1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .guide-card {
    animation: guide-fade-up 0.5s ease-out both;
  }

  @keyframes guide-fade-up {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
