---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
import EmptyState from '../components/EmptyState.astro';
import ErrorState from '../components/ErrorState.astro';
import PageHeader from '../components/PageHeader.astro';
import { getTheories } from '../services/theories.service';

let theories: Awaited<ReturnType<typeof getTheories>> = [];
let loadError = false;

try {
  theories = await getTheories();
} catch (error) {
  loadError = true;
  console.error('No se pudieron cargar las teorías', error);
}
---

<BaseLayout title="Teorías" description="Lee teorías del lore de BTS, conexiones simbólicas e interpretaciones de la comunidad.">
  <div class="max-w-[1280px] mx-auto px-margin-mobile md:px-margin-desktop py-stack-lg">
    <PageHeader
      tag="Comunidad"
      title="Teorías del Lore"
      description="Explora las diferentes interpretaciones, simbolismos y conexiones ocultas descubiertas y debatidas por la comunidad a lo largo de los años."
    />

    {loadError ? (
      <ErrorState
        title="No pudimos cargar las teorías"
        message="El archivo no pudo recuperar las teorías publicadas. Vuelve al inicio o intenta recargar la página."
        actionLabel="Volver al inicio"
        actionHref="/"
      />
    ) : theories.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {theories.map((theory) => (
          <Card
            id={theory.slug}
            title={theory.title}
            description={theory.content}
            tag={theory.tags ? theory.tags[0] : 'Teoría'}
            status={theory.status === 'published' ? 'Publicado' : 'Borrador'}
            href={`/theories/${theory.slug}`}
          />
        ))}
      </div>
    ) : (
      <EmptyState
        title="No hay teorías publicadas"
        description="Las interpretaciones de la comunidad aparecerán aquí cuando estén disponibles."
        actionLabel="Explorar timeline"
        actionHref="/timeline"
      />
    )}
  </div>
</BaseLayout>
