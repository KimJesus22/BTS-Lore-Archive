---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SpoilerBlock from '../../components/SpoilerBlock.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { albums } from '../../data/albums';
import type { Song, Album } from '../../types/albums';

export function getStaticPaths() {
  const paths: any[] = [];
  albums.forEach(album => {
    album.songs.forEach(song => {
      paths.push({
        params: { slug: song.slug },
        props: { song, album }
      });
    });
  });
  return paths;
}

interface Props {
  song: Song;
  album: Album;
}

const { song, album } = Astro.props;
---

<BaseLayout title={`${song.title} | Canciones`} description={song.loreSummary || `Detalle de la canción ${song.title} del álbum ${album.title}`}>
  
  <article class="max-w-[800px] mx-auto px-margin-mobile md:px-margin-desktop py-stack-lg">
    
    <header class="mb-12 md:mb-16">
      <Breadcrumbs items={[{ label: 'Álbumes', href: '/albums' }, { label: album.title, href: `/albums/${album.slug}` }, { label: song.title }]} />

      <div class="flex flex-col gap-4">
        <div class="flex flex-wrap items-center gap-4">
          <span class="label-caps px-3 py-1 bg-white/5 rounded-full border border-white/10">Track {String(song.trackNumber).padStart(2, '0')}</span>
          <a href={`/eras/${album.eraSlug}`} class="label-caps px-3 py-1 bg-primary/10 text-primary-light rounded-full border border-primary/20 hover:bg-primary/20 transition-colors">
            Era: {album.eraSlug.toUpperCase()}
          </a>
        </div>
        
        <h1 class="text-headline-lg md:text-display-sm font-serif text-on-surface leading-tight mt-2">{song.title}</h1>
      </div>
    </header>

    <SpoilerBlock level={album.spoilerLevel ?? 'none'}>
      <section class="mt-8">
        <div class="glass-card p-6 md:p-8">
          <h2 class="text-xl font-serif font-bold text-on-surface mb-6 border-b border-white/5 pb-4">Análisis del Lore</h2>
          
          {song.loreSummary ? (
            <p class="text-on-surface-variant leading-relaxed text-body-lg">
              {song.loreSummary}
            </p>
          ) : (
            <p class="text-on-surface-variant/60 italic">
              Esta canción actualmente no tiene un resumen extenso de lore asignado en el archivo.
            </p>
          )}

          {(song.relatedSymbols?.length || song.relatedTheories?.length) ? (
            <div class="mt-8 pt-6 border-t border-white/5 grid grid-cols-1 md:grid-cols-2 gap-8">
              {song.relatedSymbols && song.relatedSymbols.length > 0 && (
                <div>
                  <h3 class="text-sm font-mono text-on-surface-variant/70 uppercase tracking-widest mb-4">Símbolos Conectados</h3>
                  <div class="flex flex-col gap-2">
                    {song.relatedSymbols.map((sym) => (
                      <a href={`/symbols/${sym}`} class="flex items-center gap-3 p-3 bg-secondary-dim/5 border border-secondary-dim/10 rounded-lg hover:bg-secondary-dim/10 transition-colors group">
                        <span class="text-secondary-dim group-hover:text-secondary-light">
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a1.5 1.5 0 01-1.5 1.5H10.5m0 0a2 2 0 100 4h3a2 2 0 100-4h-3m0 0l-1.5 1.5" /></svg>
                        </span>
                        <span class="text-on-surface capitalize">{sym.replace(/-/g, ' ')}</span>
                      </a>
                    ))}
                  </div>
                </div>
              )}
              
              {song.relatedTheories && song.relatedTheories.length > 0 && (
                <div>
                  <h3 class="text-sm font-mono text-on-surface-variant/70 uppercase tracking-widest mb-4">Teorías Relacionadas</h3>
                  <div class="flex flex-col gap-2">
                    {song.relatedTheories.map((theory) => (
                      <a href={`/theories/${theory}`} class="flex items-center gap-3 p-3 bg-primary/5 border border-primary/10 rounded-lg hover:bg-primary/10 transition-colors group">
                        <span class="text-primary-light/70 group-hover:text-primary-light">
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" /></svg>
                        </span>
                        <span class="text-on-surface capitalize">{theory.replace(/-/g, ' ')}</span>
                      </a>
                    ))}
                  </div>
                </div>
              )}
            </div>
          ) : null}
        </div>
      </section>

      <section class="mt-12">
        <div class="bg-amber-500/10 border border-amber-500/20 rounded-xl p-6 relative overflow-hidden">
          <div class="absolute -right-4 -top-4 text-amber-500/10">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-24 h-24">
              <path fill-rule="evenodd" d="M9.401 3.003c1.155-2 4.043-2 5.197 0l7.355 12.748c1.154 2-.29 4.5-2.599 4.5H4.645c-2.309 0-3.752-2.5-2.598-4.5L9.4 3.003zM12 8.25a.75.75 0 01.75.75v3.75a.75.75 0 01-1.5 0V9a.75.75 0 01.75-.75zm0 8.25a.75.75 0 100-1.5.75.75 0 000 1.5z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="relative z-10">
            <h3 class="text-lg font-serif font-bold text-amber-400 mb-3 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
              Interpretaciones posibles
            </h3>
            <p class="text-sm text-amber-200/80 leading-relaxed mb-4">
              Ten en cuenta que el universo narrativo (BU) es intencionalmente ambiguo. Las siguientes interpretaciones son subjetivas, construidas a partir de teorías de la comunidad y análisis de videos, pero pueden variar según el observador y no constituyen verdades absolutas.
            </p>
            <div class="bg-surface/50 border border-white/5 rounded-lg p-5">
              <p class="text-on-surface-variant text-sm italic">
                (Las interpretaciones detalladas para <strong>{song.title}</strong> se irán expandiendo a medida que se conecten más piezas del archivo y teorías de la comunidad.)
              </p>
            </div>
          </div>
        </div>
      </section>
    </SpoilerBlock>
    
  </article>
</BaseLayout>
