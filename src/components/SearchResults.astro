---
import EmptyState from './EmptyState.astro';
import type { SearchResultsByGroup } from '../services/search.service';

interface Props {
  index: SearchResultsByGroup;
}

const { index } = Astro.props;
const serializedIndex = JSON.stringify(index).replace(/</g, '\\u003c');
---

<div id="search-initial-state">
  <EmptyState title="Busca en todo el archivo" description="Escribe una palabra, símbolo, miembro, era o concepto para explorar el BTS Lore Archive." />
</div>

<div id="search-empty-state" class="hidden">
  <EmptyState title="No se encontraron resultados" description="Prueba con otro nombre, símbolo o concepto del lore." />
</div>

<div id="search-results" class="hidden space-y-10"></div>

<script is:inline id="search-index" type="application/json" set:html={serializedIndex}></script>

<script>
  type SearchGroupKey = 'eras' | 'members' | 'timeline' | 'theories' | 'glossary';

  interface SearchResult {
    id: string;
    title: string;
    description: string;
    type: string;
    href: string;
    searchableText: string;
  }

  type SearchResultsByGroup = Record<SearchGroupKey, SearchResult[]>;

  const groupLabels: Array<{ key: SearchGroupKey; title: string }> = [
    { key: 'eras', title: 'Eras' },
    { key: 'members', title: 'Miembros' },
    { key: 'timeline', title: 'Cronología' },
    { key: 'theories', title: 'Teorías' },
    { key: 'glossary', title: 'Glosario' },
  ];

  const normalize = (value: string) =>
    value
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '');

  const indexElement = document.getElementById('search-index');
  const initialState = document.getElementById('search-initial-state');
  const emptyState = document.getElementById('search-empty-state');
  const resultsRoot = document.getElementById('search-results');
  const query = new URLSearchParams(window.location.search).get('q')?.trim() ?? '';
  const index = JSON.parse(indexElement?.textContent ?? '{}') as SearchResultsByGroup;

  const createText = (tag: string, className: string, text: string) => {
    const element = document.createElement(tag);
    element.className = className;
    element.textContent = text;
    return element;
  };

  const filterResults = (rawQuery: string) => {
    const cleanQuery = normalize(rawQuery);
    const groups = {} as SearchResultsByGroup;

    groupLabels.forEach(({ key }) => {
      groups[key] = (index[key] ?? []).filter((item) => normalize(item.searchableText).includes(cleanQuery));
    });

    return groups;
  };

  const countResults = (groups: SearchResultsByGroup) =>
    groupLabels.reduce((total, { key }) => total + groups[key].length, 0);

  const showOnly = (state: 'initial' | 'empty' | 'results') => {
    initialState?.classList.toggle('hidden', state !== 'initial');
    emptyState?.classList.toggle('hidden', state !== 'empty');
    resultsRoot?.classList.toggle('hidden', state !== 'results');
  };

  const renderResults = () => {
    if (!resultsRoot) return;

    if (!query) {
      showOnly('initial');
      return;
    }

    const groups = filterResults(query);
    const total = countResults(groups);

    if (total === 0) {
      showOnly('empty');
      return;
    }

    resultsRoot.replaceChildren();

    const summary = document.createElement('div');
    summary.className = 'flex flex-col gap-2 border-b border-border/50 pb-5 sm:flex-row sm:items-end sm:justify-between';

    const summaryText = document.createElement('div');
    summaryText.append(
      createText('p', 'label-caps text-primary-light', 'Resultados'),
      createText('h2', 'mt-2 text-headline-md font-serif text-on-surface', `${total} coincidencia${total === 1 ? '' : 's'}`),
    );

    const queryText = createText('p', 'text-sm text-on-surface-variant', `Búsqueda: "${query}"`);
    summary.append(summaryText, queryText);
    resultsRoot.append(summary);

    groupLabels.forEach(({ key, title }) => {
      const items = groups[key];
      if (items.length === 0) return;

      const section = document.createElement('section');
      section.className = 'space-y-4';

      const headingRow = document.createElement('div');
      headingRow.className = 'flex items-center gap-3';
      headingRow.append(
        createText('h3', 'text-xl font-serif text-on-surface', title),
        createText('span', 'label-caps rounded-full border border-primary/25 bg-primary/15 px-3 py-1 text-primary-light', String(items.length)),
      );

      const grid = document.createElement('div');
      grid.className = 'grid grid-cols-1 gap-4';

      items.forEach((item) => {
        const link = document.createElement('a');
        link.href = item.href;
        link.className = 'glass-card group block p-5 md:p-6';

        const meta = document.createElement('div');
        meta.className = 'mb-3 flex flex-wrap items-center gap-2';
        meta.append(createText('span', 'label-caps rounded-full border border-secondary-dim/25 bg-secondary-dim/10 px-3 py-1 text-secondary-dim', item.type));

        link.append(
          meta,
          createText('h4', 'text-xl font-serif text-on-surface transition-colors group-hover:text-primary-light', item.title),
          createText('p', 'mt-2 text-sm leading-relaxed text-on-surface-variant', item.description),
        );

        grid.append(link);
      });

      section.append(headingRow, grid);
      resultsRoot.append(section);
    });

    showOnly('results');
  };

  renderResults();
</script>
