---
import { navigation } from '../data/navigation';
---

<footer class="mt-stack-lg border-t border-border bg-surface-dim py-12">
  <div class="max-w-[1280px] mx-auto px-margin-mobile md:px-margin-desktop">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="md:col-span-2">
        <h3 class="font-serif text-xl font-bold text-on-surface mb-4">Archivo Cósmico</h3>
        <p class="text-on-surface-variant font-sans text-sm max-w-sm">
          Un repositorio de alta fidelidad del lore del universo de BTS. Documentando las líneas de tiempo, los personajes y las narrativas interconectadas.
        </p>
      </div>

      <div>
        <h4 class="label-caps mb-4">Exploración</h4>
        <ul class="space-y-2">
          {navigation.map((item) => (
            <li>
              <a href={item.href} class="text-on-surface-variant hover:text-primary-light transition-colors text-sm">
                {item.name}
              </a>
            </li>
          ))}
          <li>
            <a href="/guides" class="text-on-surface-variant hover:text-primary-light transition-colors text-sm">
              Rutas de lectura
            </a>
          </li>
          <li>
            <a href="/checklist" class="text-on-surface-variant hover:text-primary-light transition-colors text-sm">
              Checklist
            </a>
          </li>
          <li>
            <a href="/about" class="text-on-surface-variant hover:text-primary-light transition-colors text-sm">
              Acerca del proyecto
            </a>
          </li>
          <li>
            <a href="/roadmap" class="text-on-surface-variant hover:text-primary-light transition-colors text-sm">
              Roadmap
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h4 class="label-caps mb-4">Conectar</h4>
        <ul class="space-y-2">
          <li><a href="javascript:void(0)" class="text-on-surface-variant hover:text-primary-light transition-colors text-sm">Twitter</a></li>
          <li><a href="javascript:void(0)" class="text-on-surface-variant hover:text-primary-light transition-colors text-sm">Discord</a></li>
          <li><a href="/about#como-contribuir" class="text-on-surface-variant hover:text-primary-light transition-colors text-sm">Contribuir</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-border/50 text-center text-xs text-on-surface-variant/70">
      &copy; {new Date().getFullYear()} BTS Lore Archive. Proyecto fan-made creado con fines educativos y de archivo.
    </div>
  </div>
</footer>
