---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FavoriteButton from '../../components/FavoriteButton.astro';
import PersonalNotes from '../../components/PersonalNotes.astro';
import TimelineNode from '../../components/TimelineNode.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getEras } from '../../services/eras.service';
import type { Era } from '../../types/content';

export async function getStaticPaths() {
  const eras = await getEras();
  return eras.map((era) => {
    return {
      params: { id: era.id },
      props: { era },
    };
  });
}

interface Props {
  era: Era;
}

const { era } = Astro.props;
const eraState = era.end_year ? 'Completado' : 'Activo';
const metaDescription = era.description.length > 155 ? `${era.description.slice(0, 155).trim()}...` : era.description;
---

<BaseLayout title={era.title} description={metaDescription} canonical={`/eras/${era.id}`}>
  <article class="max-w-[1280px] mx-auto px-margin-mobile md:px-margin-desktop py-stack-lg">
    
    <header class="mb-16 pb-8 border-b border-border/50">
      <Breadcrumbs items={[{ label: 'Eras', href: '/eras' }, { label: era.title }]} />

      <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
        <div>
          <h1 class="text-display-lg-mobile md:text-display-lg font-serif font-bold text-on-surface mb-4">{era.title}</h1>
          <div class="flex items-center gap-4 text-primary-light label-caps mb-6">
            <span>{era.start_year} - {era.end_year || 'Presente'}</span>
            <span class="w-1.5 h-1.5 rounded-full bg-secondary-dim"></span>
            <span>{eraState}</span>
          </div>
        </div>
        <FavoriteButton
          id={era.id}
          type="era"
          title={era.title}
          description={era.description}
          href={`/eras/${era.id}`}
        />
      </div>
      <p class="text-body-md md:text-body-lg text-on-surface-variant max-w-3xl leading-relaxed">{era.description}</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-16">
      <div class="lg:col-span-2">
        <h2 class="text-headline-md font-serif text-on-surface mb-8">Eventos Clave</h2>
        <div class="space-y-8 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-border before:to-transparent">
          {/* Mock events for this specific era view */}
          <TimelineNode date="Primavera" title="El Inicio" description="Los siete se encuentran por primera vez en el salón de clases vacío que convirtieron en su refugio." />
          <TimelineNode date="Verano" title="El Viaje al Mar" description="Bajo el sol de verano, deciden hacer un viaje improvisado hacia el mar, buscando un respiro de la realidad." />
          <TimelineNode date="Otoño" title="La Separación" description="Conflictos internos y presiones externas fuerzan al grupo a separarse, iniciando un periodo de soledad y oscuridad." />
        </div>
      </div>

      <div class="space-y-6">
        <h3 class="text-headline-md font-serif text-on-surface mb-4">Artefactos</h3>
        <div class="glass-card p-6">
          <div class="w-12 h-12 bg-primary/20 rounded-full mb-4 border border-primary/30 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-primary-light">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <h4 class="font-bold text-on-surface mb-2">Las Notas</h4>
          <p class="text-sm text-on-surface-variant font-sans">Registros dispersos que documentan los pensamientos de cada miembro.</p>
        </div>
      </div>
    </div>

    <div class="mt-14">
      <PersonalNotes contentType="era" contentSlug={era.slug} title={era.title} href={`/eras/${era.id}`} />
    </div>
    
  </article>
</BaseLayout>
