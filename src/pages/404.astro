---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
---

<BaseLayout title="Esta conexión se perdió" description="Página no encontrada en BTS Lore Archive.">
  <div class="relative min-h-[70vh] flex items-center justify-center overflow-hidden py-16">
    <!-- Starfield/Glow background effects -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-primary/10 rounded-full blur-[100px] opacity-60"></div>
      <div class="absolute top-1/3 left-1/3 w-[300px] h-[300px] bg-secondary-dim/5 rounded-full blur-[80px] opacity-40"></div>
    </div>

    <div class="relative z-10 max-w-[680px] mx-auto px-margin-mobile md:px-margin-desktop text-center">
      
      <!-- Cosmic Abstract Graphic -->
      <div class="flex justify-center mb-8">
        <div class="cosmic-portal-container relative w-64 h-64 flex items-center justify-center">
          <!-- Outer rotating nebula glow -->
          <div class="absolute inset-0 bg-gradient-to-tr from-primary/30 via-transparent to-secondary-dim/30 rounded-full blur-xl animate-[spin_15s_linear_infinite]"></div>
          
          <svg class="cosmic-portal w-56 h-56 text-primary-light" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Outer dashed rings -->
            <circle cx="100" cy="100" r="85" stroke="url(#ringGradient)" stroke-width="1.5" stroke-dasharray="10 6" class="animate-[spin_50s_linear_infinite]" />
            <circle cx="100" cy="100" r="65" stroke="url(#ringGradient)" stroke-width="1.2" stroke-dasharray="16 8" class="animate-[spin_30s_linear_infinite_reverse]" opacity="0.7" />
            <circle cx="100" cy="100" r="45" stroke="url(#ringGradient)" stroke-width="2" class="animate-pulse" opacity="0.5" />
            
            <!-- Fragmented orbit arcs representing the lost connection -->
            <path d="M30,100 A70,70 0 0,1 170,100" stroke="url(#lineGradient)" stroke-width="3" stroke-linecap="round" stroke-dasharray="8 120" class="animate-[dash_8s_linear_infinite]" />
            <path d="M170,100 A70,70 0 0,1 30,100" stroke="url(#yellowGradient)" stroke-width="2" stroke-linecap="round" stroke-dasharray="4 90" class="animate-[dash_6s_linear_infinite_reverse]" />
            
            <!-- Pulsating glitched core star -->
            <g class="animate-[spin_20s_ease-in-out_infinite]">
              <path d="M100 65 L106 94 L135 100 L106 106 L100 135 L94 106 L65 100 L94 94 Z" fill="url(#coreGradient)" />
              <circle cx="100" cy="100" r="6" fill="#fde047" class="animate-ping" />
              <!-- Glitched split indicator -->
              <line x1="80" y1="100" x2="120" y2="100" stroke="#fde047" stroke-width="2" stroke-dasharray="4 6" opacity="0.8" />
            </g>

            <defs>
              <linearGradient id="ringGradient" x1="0" y1="0" x2="200" y2="200" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="#6d28d9" />
                <stop offset="50%" stop-color="#d3bbff" stop-opacity="0.3" />
                <stop offset="100%" stop-color="#e9c349" />
              </linearGradient>
              <linearGradient id="lineGradient" x1="0" y1="0" x2="200" y2="200" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="#d3bbff" />
                <stop offset="100%" stop-color="#6d28d9" />
              </linearGradient>
              <linearGradient id="yellowGradient" x1="200" y1="200" x2="0" y2="0" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="#e9c349" />
                <stop offset="100%" stop-color="transparent" />
              </linearGradient>
              <radialGradient id="coreGradient" cx="100" cy="100" r="35" fx="100" fy="100" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="#d3bbff" />
                <stop offset="50%" stop-color="#6d28d9" stop-opacity="0.9" />
                <stop offset="100%" stop-color="transparent" />
              </radialGradient>
            </defs>
          </svg>
        </div>
      </div>

      <!-- Main Messages -->
      <h1 class="text-display-lg-mobile md:text-display-lg font-serif font-bold text-white mb-6 leading-tight tracking-tight drop-shadow-[0_0_35px_rgba(211,187,255,0.25)]">
        Esta conexión del lore se perdió
      </h1>
      
      <p class="text-body-md md:text-body-lg text-on-surface-variant max-w-lg mx-auto leading-relaxed mb-12">
        La página que buscas no existe o fue movida a otra era.
      </p>

      <!-- Action Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href="/" variant="primary" class="w-full sm:w-auto min-w-[170px]">
          Volver al inicio
        </Button>
        <Button href="/eras" variant="secondary" class="w-full sm:w-auto min-w-[170px]">
          Explorar eras
        </Button>
        <Button href="/search" variant="ghost" class="w-full sm:w-auto min-w-[170px] border border-white/5 hover:border-white/10">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 mr-2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.603 10.602z" />
          </svg>
          Buscar
        </Button>
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  @keyframes space-warp {
    0%, 100% {
      transform: scale(1);
      filter: drop-shadow(0 0 15px rgba(211, 187, 255, 0.4));
    }
    50% {
      transform: scale(1.03);
      filter: drop-shadow(0 0 35px rgba(211, 187, 255, 0.6)) drop-shadow(0 0 20px rgba(233, 195, 73, 0.25));
    }
  }

  @keyframes floating {
    0%, 100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-8px);
    }
  }

  @keyframes dash {
    to {
      stroke-dashoffset: -128;
    }
  }

  .cosmic-portal {
    animation: space-warp 12s ease-in-out infinite;
  }

  .cosmic-portal-container {
    animation: floating 6s ease-in-out infinite;
  }
</style>
