---
// EraForm.astro
---
<div class="glass-card p-6">
  <h3 class="font-serif text-xl text-on-surface mb-4">Añadir Nueva Era</h3>
  <form id="era-form" class="space-y-4">
    <div>
      <label class="block text-sm text-on-surface-variant mb-1">Título</label>
      <input type="text" name="title" required class="w-full bg-surface-dim border border-border rounded px-3 py-2 text-on-surface" />
    </div>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-sm text-on-surface-variant mb-1">Año Inicio</label>
        <input type="number" name="start_year" class="w-full bg-surface-dim border border-border rounded px-3 py-2 text-on-surface" />
      </div>
      <div>
        <label class="block text-sm text-on-surface-variant mb-1">Año Fin</label>
        <input type="number" name="end_year" class="w-full bg-surface-dim border border-border rounded px-3 py-2 text-on-surface" />
      </div>
    </div>
    <div>
      <label class="block text-sm text-on-surface-variant mb-1">Descripción</label>
      <textarea name="description" required rows="3" class="w-full bg-surface-dim border border-border rounded px-3 py-2 text-on-surface"></textarea>
    </div>
    <button type="submit" class="bg-primary text-on-primary px-4 py-2 rounded font-semibold w-full hover:bg-primary-light transition-colors">
      Guardar Era
    </button>
    <p id="era-msg" class="text-sm text-center hidden mt-2"></p>
  </form>
</div>

<script>
  import { createEra } from '../../services/eras.service';
  import { logAdminAction } from '../../utils/adminHistory';

  const form = document.getElementById('era-form') as HTMLFormElement;
  const msg = document.getElementById('era-msg');

  if (form && msg) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const title = formData.get('title') as string;
      
      const newEra = {
        id: crypto.randomUUID(),
        title,
        slug: title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)+/g, ''),
        description: formData.get('description') as string,
        start_year: formData.get('start_year') ? parseInt(formData.get('start_year') as string) : undefined,
        end_year: formData.get('end_year') ? parseInt(formData.get('end_year') as string) : undefined,
        order_index: 0,
        // TODO: Seguridad - El token del admin se enviaría implícitamente si se usa autenticación en InsForge
      };

      try {
        msg.textContent = 'Guardando...';
        msg.className = 'text-sm text-center mt-2 text-on-surface-variant block';
        
        await createEra(newEra);
        
        msg.textContent = '¡Era guardada exitosamente!';
        msg.className = 'text-sm text-center mt-2 text-primary-light block';
        logAdminAction('created_era', 'era', title);
        form.reset();
      } catch (err) {
        console.error(err);
        msg.textContent = 'Error al guardar la Era. Revisa la consola.';
        msg.className = 'text-sm text-center mt-2 text-red-400 block';
      }
    });
  }
</script>
