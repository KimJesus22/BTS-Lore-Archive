---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmptyState from '../components/EmptyState.astro';
import PageHeader from '../components/PageHeader.astro';
---

<BaseLayout title="Notas personales" description="Notas privadas guardadas localmente en BTS Lore Archive.">
  <div class="max-w-[960px] mx-auto px-margin-mobile md:px-margin-desktop py-stack-lg">
    <PageHeader
      tag="Archivo privado"
      title="Notas personales"
      description="Revisa las notas guardadas en este navegador sobre eras, teorías y términos del glosario."
      align="left"
    />

    <div id="notes-empty">
      <EmptyState title="No hay notas todavía" description="Escribe una nota en una era, teoría o término del glosario para verla aquí." />
    </div>

    <div id="notes-list" class="hidden space-y-8"></div>
  </div>
</BaseLayout>

<script>
  interface PersonalNote {
    contentType: string;
    contentSlug: string;
    title?: string;
    href?: string;
    text: string;
    updatedAt: string;
  }

  const notesStorageKey = 'bts-lore-notes';
  const list = document.getElementById('notes-list');
  const empty = document.getElementById('notes-empty');
  const typeLabels: Record<string, string> = {
    era: 'Eras',
    theory: 'Teorías',
    glossary: 'Glosario',
  };
  const typePath: Record<string, string> = {
    era: '/eras',
    theory: '/theories',
    glossary: '/glossary',
  };

  const readNotes = (): PersonalNote[] => {
    try {
      const stored = window.localStorage.getItem(notesStorageKey);
      return stored ? JSON.parse(stored) : [];
    } catch {
      return [];
    }
  };

  const writeNotes = (notes: PersonalNote[]) => {
    window.localStorage.setItem(notesStorageKey, JSON.stringify(notes));
    window.dispatchEvent(new CustomEvent('bts-lore-notes-updated'));
  };

  const createText = (tag: string, className: string, text: string) => {
    const element = document.createElement(tag);
    element.className = className;
    element.textContent = text;
    return element;
  };

  const formatDate = (value: string) => {
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return 'Fecha no registrada';

    return new Intl.DateTimeFormat('es-MX', {
      day: 'numeric',
      month: 'short',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
    }).format(date);
  };

  const hrefForNote = (note: PersonalNote) => {
    if (note.href) return note.href;
    if (note.contentType === 'glossary') return `/glossary#${note.contentSlug}`;
    return `${typePath[note.contentType] ?? ''}/${note.contentSlug}`;
  };

  const removeNote = (note: PersonalNote) => {
    const nextNotes = readNotes().filter((item) => !(item.contentType === note.contentType && item.contentSlug === note.contentSlug));
    writeNotes(nextNotes);
    renderNotes();
  };

  const renderNotes = () => {
    const notes = readNotes().sort((a, b) => b.updatedAt.localeCompare(a.updatedAt));

    empty?.classList.toggle('hidden', notes.length > 0);
    list?.classList.toggle('hidden', notes.length === 0);
    list?.replaceChildren();

    if (!list || notes.length === 0) return;

    Object.keys(typeLabels).forEach((type) => {
      const groupedNotes = notes.filter((note) => note.contentType === type);
      if (groupedNotes.length === 0) return;

      const section = document.createElement('section');
      section.className = 'space-y-4';

      const heading = document.createElement('div');
      heading.className = 'flex items-center gap-3';
      heading.append(
        createText('h2', 'text-headline-md font-serif text-on-surface', typeLabels[type]),
        createText('span', 'label-caps rounded-full border border-primary/25 bg-primary/15 px-3 py-1 text-primary-light', String(groupedNotes.length)),
      );

      const cards = document.createElement('div');
      cards.className = 'space-y-4';

      groupedNotes.forEach((note) => {
        const card = document.createElement('article');
        card.className = 'glass-card p-5 md:p-6';

        const top = document.createElement('div');
        top.className = 'mb-4 flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between';

        const titleGroup = document.createElement('div');
        titleGroup.append(
          createText('p', 'label-caps text-secondary-dim', formatDate(note.updatedAt)),
          createText('h3', 'mt-2 text-xl font-serif text-on-surface', note.title || note.contentSlug),
        );

        const removeButton = document.createElement('button');
        removeButton.type = 'button';
        removeButton.className = 'rounded-full border border-white/10 px-4 py-2 text-sm font-semibold text-on-surface-variant transition-colors hover:border-secondary-dim/40 hover:text-secondary-dim';
        removeButton.textContent = 'Borrar';
        removeButton.addEventListener('click', () => removeNote(note));

        top.append(titleGroup, removeButton);

        const text = createText('p', 'whitespace-pre-line text-sm leading-relaxed text-on-surface-variant', note.text);
        const link = document.createElement('a');
        link.href = hrefForNote(note);
        link.className = 'mt-5 inline-flex text-sm font-semibold text-primary-light transition-colors hover:text-white';
        link.textContent = 'Abrir registro';

        card.append(top, text, link);
        cards.append(card);
      });

      section.append(heading, cards);
      list.append(section);
    });
  };

  renderNotes();
  window.addEventListener('storage', renderNotes);
  window.addEventListener('bts-lore-notes-updated', renderNotes);
</script>
