---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Card from '../../components/Card.astro';
import EmptyState from '../../components/EmptyState.astro';
import { albums } from '../../data/albums';

const title = "Discografía";
const description = "Explora los álbumes y canciones del BTS Universe, conectando las letras y MVs con los eventos clave del lore y sus símbolos ocultos.";
---

<BaseLayout title={title} description={description}>
  <PageHeader title={title} description={description} tag="Música" />

  <div class="max-w-[1280px] mx-auto px-margin-mobile md:px-margin-desktop pb-stack-lg">
    {albums.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {albums.map((album) => (
          <a href={`/albums/${album.slug}`} class="block group">
            <div class="glass-card overflow-hidden h-full flex flex-col group-hover:-translate-y-1 transition-transform duration-300">
              {/* Abstract Placeholder Cover */}
              <div class="aspect-square w-full relative bg-surface border-b border-white/5 overflow-hidden">
                <div class="absolute inset-0 opacity-20 group-hover:opacity-40 transition-opacity duration-500">
                  <div class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-primary/40 via-surface to-surface"></div>
                </div>
                <div class="absolute inset-0 flex items-center justify-center">
                  <span class="font-serif text-3xl font-bold text-white/10 group-hover:text-primary/20 transition-colors tracking-widest uppercase text-center px-4">
                    {album.title.split(' ')[0]}
                  </span>
                </div>
              </div>
              
              <div class="p-6 md:p-8 flex-1 flex flex-col">
                <p class="label-caps mb-3">{album.releaseDate.split('-')[0]}</p>
                <h2 class="text-xl font-serif font-bold text-on-surface mb-3 group-hover:text-primary-light transition-colors">{album.title}</h2>
                <p class="text-on-surface-variant text-sm line-clamp-3 mb-6 flex-1">{album.description}</p>
                
                <div class="flex flex-wrap gap-2 mt-auto">
                  {album.themes.slice(0, 3).map((theme) => (
                    <span class="text-xs font-mono px-2 py-1 bg-white/5 rounded-md text-on-surface-variant/80 border border-white/10">
                      {theme}
                    </span>
                  ))}
                  {album.themes.length > 3 && (
                    <span class="text-xs font-mono px-2 py-1 text-on-surface-variant/50">
                      +{album.themes.length - 3}
                    </span>
                  )}
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <EmptyState 
        title="Sin álbumes documentados" 
        description="Aún no hemos conectado la discografía con los eventos del lore." 
      />
    )}
  </div>
</BaseLayout>
