---
import { navigation } from '../data/navigation';
---

<header class="sticky top-0 z-50 w-full bg-surface/70 backdrop-blur-xl border-b border-border">
  <div class="max-w-[1280px] mx-auto px-margin-mobile md:px-margin-desktop h-20 flex items-center justify-between">
    <div class="flex-shrink-0 mr-8">
      <a href="/" class="font-serif text-xl sm:text-2xl font-bold text-on-surface">
        Cosmic<span class="text-primary-light">Archive</span>
      </a>
    </div>
    
    <nav class="hidden md:flex gap-5 items-center">
      {navigation.map((item) => (
        <a href={item.href} class="text-on-surface-variant hover:text-primary-light transition-colors font-sans text-sm tracking-wide">
          {item.name}
        </a>
      ))}
      <a href="/settings" class="text-on-surface-variant hover:text-primary-light transition-colors font-sans text-sm tracking-wide flex items-center gap-1" title="Configuración">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
      </a>
      <button
        type="button"
        class="spoiler-toggle flex h-9 items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 text-xs font-semibold text-on-surface-variant hover:border-primary/40 hover:text-primary-light transition-all"
        data-active="false"
        aria-pressed="false"
        aria-label="Activar modo sin spoilers"
        title="Modo sin spoilers"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 spoiler-icon-eye">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.64 0 8.577 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.64 0-8.577-3.007-9.963-7.178z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 spoiler-icon-slash hidden">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />
        </svg>
        <span class="spoiler-label">Spoilers</span>
      </button>
    </nav>

    <div class="md:hidden">
      <button id="mobile-menu-toggle" class="flex h-11 w-11 items-center justify-center rounded-full border border-white/10 bg-white/5 text-on-surface-variant hover:text-white" aria-label="Abrir menú" aria-expanded="false" aria-controls="mobile-menu">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="fixed inset-x-0 top-20 hidden border-b border-white/10 bg-surface/95 px-margin-mobile py-6 shadow-[0_24px_80px_rgba(0,0,0,0.45)] backdrop-blur-2xl md:hidden">
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top_left,rgba(109,40,217,0.22),transparent_35%),radial-gradient(circle_at_bottom_right,rgba(233,195,73,0.12),transparent_32%)]"></div>
    <nav class="flex flex-col gap-3" aria-label="Navegación móvil">
      {navigation.map((item) => (
        <a href={item.href} class="rounded-xl border border-white/10 bg-white/[0.03] px-5 py-4 text-base font-semibold text-on-surface transition-colors hover:border-primary/40 hover:bg-primary/10">
          {item.name}
        </a>
      ))}
      <a href="/settings" class="rounded-xl border border-white/10 bg-white/[0.03] px-5 py-4 text-base font-semibold text-on-surface transition-colors hover:border-primary/40 hover:bg-primary/10 flex items-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-on-surface-variant">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        Configuración
      </a>
      <button
        type="button"
        class="spoiler-toggle rounded-xl border border-white/10 bg-white/[0.03] px-5 py-4 text-base font-semibold text-on-surface transition-colors hover:border-primary/40 hover:bg-primary/10 text-left flex items-center gap-3"
        data-active="false"
        aria-pressed="false"
        aria-label="Activar modo sin spoilers"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 spoiler-icon-eye">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.64 0 8.577 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.64 0-8.577-3.007-9.963-7.178z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 spoiler-icon-slash hidden">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />
        </svg>
        <span class="spoiler-label">Modo sin spoilers</span>
      </button>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const links = menu?.querySelectorAll('a') ?? [];

  const setOpen = (open: boolean) => {
    menu?.classList.toggle('hidden', !open);
    toggle?.setAttribute('aria-expanded', String(open));
    toggle?.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
  };

  toggle?.addEventListener('click', () => {
    setOpen(toggle.getAttribute('aria-expanded') !== 'true');
  });

  links.forEach((link) => {
    link.addEventListener('click', () => setOpen(false));
  });

  // Observers for spoiler toggle icon swap (since state is updated globally)
  const syncSpoilerIcons = () => {
    document.querySelectorAll<HTMLElement>('.spoiler-toggle').forEach((btn) => {
      const isActive = btn.dataset.active === 'true';
      const eyeIcon = btn.querySelector('.spoiler-icon-eye');
      const slashIcon = btn.querySelector('.spoiler-icon-slash');

      eyeIcon?.classList.toggle('hidden', isActive);
      slashIcon?.classList.toggle('hidden', !isActive);

      if (isActive) {
        btn.classList.add('border-primary/40', 'text-primary-light');
        btn.classList.remove('border-white/10', 'text-on-surface-variant');
      } else {
        btn.classList.remove('border-primary/40', 'text-primary-light');
        btn.classList.add('border-white/10', 'text-on-surface-variant');
      }
    });
  };

  const observer = new MutationObserver(syncSpoilerIcons);
  document.querySelectorAll<HTMLElement>('.spoiler-toggle').forEach((btn) => {
    observer.observe(btn, { attributes: true, attributeFilter: ['data-active'] });
    
    // Add click listener that proxies to the new global settings manager
    btn.addEventListener('click', () => {
      const currentActive = btn.dataset.active === 'true';
      if (window.updateLoreSettings) {
        window.updateLoreSettings({ spoilerSafe: !currentActive });
      }
    });
  });

  // Initial sync
  syncSpoilerIcons();
</script>
