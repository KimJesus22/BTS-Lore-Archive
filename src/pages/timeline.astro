---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmptyState from '../components/EmptyState.astro';
import ErrorState from '../components/ErrorState.astro';
import TimelineNode from '../components/TimelineNode.astro';
import PageHeader from '../components/PageHeader.astro';
import { getEras } from '../services/eras.service';
import { getTimelineEvents } from '../services/timeline.service';

let timelineEvents: Awaited<ReturnType<typeof getTimelineEvents>> = [];
let eras: Awaited<ReturnType<typeof getEras>> = [];
let loadError = false;

try {
  [timelineEvents, eras] = await Promise.all([
    getTimelineEvents(),
    getEras(),
  ]);
} catch (error) {
  loadError = true;
  console.error('No se pudo cargar la línea de tiempo', error);
}

const eraSlugById = new Map(eras.map((era) => [era.id, era.slug]));

const eraFilters = [
  { label: 'Todas', value: 'all' },
  { label: 'HYYH', value: 'hyyh' },
  { label: 'Wings', value: 'wings' },
  { label: 'Love Yourself', value: 'love-yourself' },
  { label: 'Map of the Soul', value: 'map-of-the-soul' },
  { label: 'BE', value: 'be' },
  { label: 'Proof', value: 'proof' },
  { label: 'Solos', value: 'solos' },
];

const sourceTypes = [
  'MV', 'Letra', 'Short film', 'Notes', 'Webtoon',
  'Teoría fan', 'Álbum', 'Entrevista', 'Otro'
];
---

<BaseLayout title="Línea de Tiempo" description="Recorre la cronología del universo narrativo de BTS y filtra eventos por era y tipo de fuente.">
  <div class="max-w-[1280px] mx-auto px-margin-mobile md:px-margin-desktop py-stack-lg">
    <PageHeader
      tag="Registro Cronológico"
      title="Línea de Tiempo del Universo"
      description="Los eventos clave que definen la narrativa, ordenados cronológicamente desde el año 22."
    />

    {loadError ? (
      <ErrorState
        title="No pudimos cargar la cronología"
        message="Hubo un problema al reunir los eventos y sus eras relacionadas. Vuelve al inicio o recarga la página."
        actionLabel="Volver al inicio"
        actionHref="/"
      />
    ) : timelineEvents.length > 0 ? (
      <>
        <section class="mx-auto mb-10 max-w-4xl">
          <div class="glass-card p-5 md:p-6 space-y-6">
            
            {/* Filtro por Era */}
            <div>
              <div class="mb-3 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
                <p class="label-caps text-primary-light">Filtrar por era</p>
              </div>
              <div class="flex flex-wrap gap-2" aria-label="Filtros de era">
                {eraFilters.map((filter) => (
                  <button
                    type="button"
                    data-era-filter={filter.value}
                    aria-pressed={filter.value === 'all' ? 'true' : 'false'}
                    class={`era-filter rounded-full border px-4 py-2 text-sm font-semibold transition-colors ${
                      filter.value === 'all'
                        ? 'border-primary/50 bg-primary/20 text-primary-light'
                        : 'border-white/10 bg-white/[0.03] text-on-surface-variant hover:border-primary/35 hover:text-primary-light'
                    }`}
                  >
                    {filter.label}
                  </button>
                ))}
              </div>
            </div>

            {/* Separador visual */}
            <div class="border-t border-border/50"></div>

            {/* Filtro por Tipo de Fuente */}
            <div>
              <p class="label-caps text-secondary-dim mb-3">Filtrar por tipo de fuente</p>
              <div class="flex flex-wrap gap-2" aria-label="Filtros de fuente">
                <button
                  type="button"
                  data-source-filter="all"
                  aria-pressed="true"
                  class="source-filter rounded-full border px-4 py-2 text-sm font-semibold transition-colors border-secondary-dim/50 bg-secondary-dim/15 text-secondary-dim"
                >
                  Todas
                </button>
                {sourceTypes.map((st) => (
                  <button
                    type="button"
                    data-source-filter={st}
                    aria-pressed="false"
                    class="source-filter rounded-full border px-4 py-2 text-sm font-semibold transition-colors border-white/10 bg-white/[0.03] text-on-surface-variant hover:border-secondary-dim/35 hover:text-secondary-dim"
                  >
                    {st}
                  </button>
                ))}
              </div>
            </div>

            {/* Contador */}
            <div class="pt-2 border-t border-border/50">
              <p id="timeline-count" class="text-sm text-on-surface-variant">
                {timelineEvents.length} evento{timelineEvents.length === 1 ? '' : 's'} visible{timelineEvents.length === 1 ? '' : 's'}
              </p>
            </div>

          </div>
        </section>

        <div id="timeline-empty-filter" class="mx-auto hidden max-w-4xl">
          <EmptyState title="Sin coincidencias" description="No hay eventos que coincidan con esta combinación de filtros. Prueba ampliando tu búsqueda." />
        </div>

        <div id="timeline-list" class="max-w-4xl mx-auto space-y-12 md:space-y-14">
          {timelineEvents.map((event) => (
            <TimelineNode
              id={event.slug || event.id}
              eraSlug={event.era_id ? eraSlugById.get(event.era_id) ?? 'sin-era' : 'sin-era'}
              date={event.event_date || 'Sin fecha'}
              title={event.title}
              description={event.description}
              sourceType={event.source_type}
              spoilerLevel={event.spoilerLevel}
            />
          ))}
        </div>
      </>
    ) : (
      <EmptyState
        title="No hay eventos registrados"
        description="La línea de tiempo mostrará nuevos nodos cuando existan registros publicados."
        actionLabel="Explorar eras"
        actionHref="/eras"
      />
    )}
  </div>
</BaseLayout>

<script>
  const eraButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('.era-filter'));
  const sourceButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('.source-filter'));
  const events = Array.from(document.querySelectorAll<HTMLElement>('.timeline-event'));
  const countLabel = document.getElementById('timeline-count');
  const emptyState = document.getElementById('timeline-empty-filter');

  let currentEra = 'all';
  let currentSource = 'all';

  function setActiveGroup(buttons: HTMLButtonElement[], activeValue: string, filterAttr: string, activeColor: string, activeBg: string) {
    buttons.forEach((btn) => {
      const val = btn.dataset[filterAttr] ?? '';
      const isActive = val === activeValue;
      btn.setAttribute('aria-pressed', String(isActive));

      // Reset all to default
      btn.classList.remove('border-primary/50', 'bg-primary/20', 'text-primary-light',
                           'border-secondary-dim/50', 'bg-secondary-dim/15', 'text-secondary-dim');
      btn.classList.add('border-white/10', 'bg-white/[0.03]', 'text-on-surface-variant');

      if (isActive) {
        btn.classList.remove('border-white/10', 'bg-white/[0.03]', 'text-on-surface-variant');
        btn.classList.add(activeColor, activeBg,
          filterAttr === 'eraFilter' ? 'text-primary-light' : 'text-secondary-dim');
      }
    });
  }

  function applyFilters() {
    let visibleCount = 0;

    events.forEach((event) => {
      const matchesEra = currentEra === 'all' || event.dataset.era === currentEra;
      const matchesSource = currentSource === 'all' || event.dataset.source === currentSource;

      const shouldShow = matchesEra && matchesSource;
      event.classList.toggle('hidden', !shouldShow);
      if (shouldShow) visibleCount++;
    });

    if (countLabel) {
      countLabel.textContent = `${visibleCount} evento${visibleCount === 1 ? '' : 's'} visible${visibleCount === 1 ? '' : 's'}`;
    }

    emptyState?.classList.toggle('hidden', visibleCount > 0);

    setActiveGroup(eraButtons, currentEra, 'eraFilter', 'border-primary/50', 'bg-primary/20');
    setActiveGroup(sourceButtons, currentSource, 'sourceFilter', 'border-secondary-dim/50', 'bg-secondary-dim/15');
  }

  eraButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      currentEra = btn.dataset.eraFilter ?? 'all';
      applyFilters();
    });
  });

  sourceButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      currentSource = btn.dataset.sourceFilter ?? 'all';
      applyFilters();
    });
  });
</script>
