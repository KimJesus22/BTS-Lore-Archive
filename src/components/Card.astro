---
interface Props {
  title: string;
  description: string;
  tag?: string;
  href?: string;
}

const { title, description, tag, href } = Astro.props;

const Element = href ? 'a' : 'div';
const extraProps = href ? { href } : {};
---

<Element {...extraProps} class="glass-card p-6 block group relative overflow-hidden">
  <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-white/20 to-transparent"></div>
  
  {tag && (
    <span class="inline-block px-3 py-1 rounded-full bg-primary/20 text-primary-light label-caps mb-4 border border-primary/30">
      {tag}
    </span>
  )}
  
  <h3 class="text-xl font-serif font-bold text-on-surface mb-2 group-hover:text-primary-light transition-colors">
    {title}
  </h3>
  
  <p class="text-on-surface-variant text-sm font-sans leading-relaxed">
    {description}
  </p>

  <div class="mt-6 flex items-center text-primary-light opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all">
    <span class="text-sm font-semibold tracking-wide uppercase">Explorar</span>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 ml-1">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
    </svg>
  </div>
</Element>
