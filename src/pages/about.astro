---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';

const technologies = ['Astro', 'TypeScript', 'Tailwind CSS', 'InsForge', 'Google Stitch para diseño'];
const credits = [
  'BTS y su universo narrativo como inspiración cultural.',
  'La comunidad ARMY que interpreta, ordena y conversa sobre símbolos, eras y teorías.',
  'Fuentes públicas, discusiones de fans y material de referencia usado solo como contexto.',
];
---

<BaseLayout
  title="Acerca del proyecto"
  description="Conoce qué es BTS Lore Archive, su objetivo educativo, sus créditos y su aviso fan-made."
  canonical="/about"
>
  <div class="max-w-[960px] mx-auto px-margin-mobile md:px-margin-desktop py-stack-lg">
    <PageHeader
      tag="Proyecto fan-made"
      title="Acerca de BTS Lore Archive"
      description="Un archivo en español para explorar, ordenar y estudiar el universo narrativo de BTS desde una mirada de fans."
      align="left"
    />

    <div class="space-y-8">
      <section class="glass-card p-6 md:p-8">
        <p class="label-caps text-primary-light">Qué es</p>
        <h2 class="mt-3 text-headline-md font-serif text-on-surface">Un archivo narrativo para explorar el lore</h2>
        <p class="mt-4 text-base leading-relaxed text-on-surface-variant">
          BTS Lore Archive reúne eras, eventos de cronología, personajes, símbolos, teorías y términos clave para facilitar la lectura del universo narrativo asociado a BTS. La intención es que el contenido sea fácil de consultar, comparar y conectar.
        </p>
      </section>

      <section class="glass-card p-6 md:p-8">
        <p class="label-caps text-primary-light">Objetivo</p>
        <h2 class="mt-3 text-headline-md font-serif text-on-surface">Educación, archivo y contexto</h2>
        <p class="mt-4 text-base leading-relaxed text-on-surface-variant">
          El proyecto busca servir como una guía educativa y de archivo para fans que quieren entender mejor líneas de tiempo, referencias visuales, temas recurrentes y posibles interpretaciones. No pretende reemplazar fuentes oficiales ni presentar una lectura única del lore.
        </p>
      </section>

      <section class="glass-card border-secondary-dim/30 bg-secondary-dim/10 p-6 md:p-8">
        <p class="label-caps text-secondary-dim">Aviso importante</p>
        <h2 class="mt-3 text-headline-md font-serif text-on-surface">Proyecto hecho por fans</h2>
        <ul class="mt-5 space-y-3 text-base leading-relaxed text-on-surface-variant">
          <li>Este sitio es un proyecto fan-made.</li>
          <li>No está afiliado oficialmente con BTS, HYBE ni BigHit Music.</li>
          <li>No se incluyen imágenes oficiales con copyright dentro del repositorio.</li>
        </ul>
      </section>

      <section class="glass-card p-6 md:p-8">
        <p class="label-caps text-primary-light">Tecnologías</p>
        <h2 class="mt-3 text-headline-md font-serif text-on-surface">Cómo está construido</h2>
        <div class="mt-5 flex flex-wrap gap-2">
          {technologies.map((technology) => (
            <span class="label-caps rounded-full border border-primary/25 bg-primary/15 px-3 py-1 text-primary-light">
              {technology}
            </span>
          ))}
        </div>
      </section>

      <section class="grid grid-cols-1 gap-8 md:grid-cols-2">
        <div id="como-contribuir" class="glass-card scroll-mt-28 p-6 md:p-8">
          <p class="label-caps text-primary-light">Créditos</p>
          <h2 class="mt-3 text-2xl font-serif text-on-surface">A quién se reconoce</h2>
          <ul class="mt-5 space-y-3 text-sm leading-relaxed text-on-surface-variant">
            {credits.map((credit) => <li>{credit}</li>)}
          </ul>
        </div>

        <div class="glass-card p-6 md:p-8">
          <p class="label-caps text-primary-light">Cómo contribuir</p>
          <h2 class="mt-3 text-2xl font-serif text-on-surface">Aportar al archivo</h2>
          <p class="mt-5 text-sm leading-relaxed text-on-surface-variant">
            Puedes contribuir proponiendo correcciones, nuevas teorías, términos del glosario, eventos de timeline o mejoras de accesibilidad. La prioridad es mantener contenido claro, respetuoso, en español y bien organizado.
          </p>
          <a href="/search" class="mt-6 inline-flex text-sm font-semibold text-primary-light transition-colors hover:text-white">
            Explorar el archivo
          </a>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
