---
import BaseLayout from '../layouts/BaseLayout.astro';
import ErrorState from '../components/ErrorState.astro';
import PageHeader from '../components/PageHeader.astro';
import SearchInput from '../components/SearchInput.astro';
import SearchResults from '../components/SearchResults.astro';
import { getSearchIndex } from '../services/search.service';

const query = Astro.url.searchParams.get('q')?.trim() ?? '';
let index: Awaited<ReturnType<typeof getSearchIndex>> | null = null;
let loadError = false;

try {
  index = await getSearchIndex();
} catch (error) {
  loadError = true;
  console.error('No se pudo preparar el buscador', error);
}
---

<BaseLayout title="Buscar" description="Busca eras, miembros, eventos, teorías y términos del BTS Lore Archive desde una sola página.">
  <div class="max-w-[960px] mx-auto px-margin-mobile md:px-margin-desktop py-stack-lg">
    <PageHeader
      tag="Exploración"
      title="Buscar en el Archivo"
      description="Encuentra eras, miembros, eventos, teorías y términos del glosario desde un solo lugar."
      align="left"
    />

    <div class="mb-10">
      <SearchInput query={query} />
    </div>

    {loadError || !index ? (
      <ErrorState
        title="No pudimos preparar el buscador"
        message="El índice global no está disponible en este momento. Vuelve al inicio o intenta recargar la página."
        actionLabel="Volver al inicio"
        actionHref="/"
      />
    ) : (
      <SearchResults index={index} />
    )}
  </div>
</BaseLayout>
