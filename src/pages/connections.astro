---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { mockConnections } from '../data/connections';
import { CONNECTION_TYPE_LABELS, STRENGTH_LABELS } from '../types/connections';
import type { ConnectionType, ConnectionStrength } from '../types/connections';

const typeColors: Record<ConnectionType, { bg: string; border: string; text: string }> = {
  'era': { bg: 'bg-primary/20', border: 'border-primary/30', text: 'text-primary-light' },
  'song': { bg: 'bg-rose-500/15', border: 'border-rose-500/30', text: 'text-rose-400' },
  'symbol': { bg: 'bg-emerald-500/15', border: 'border-emerald-500/30', text: 'text-emerald-400' },
  'member': { bg: 'bg-sky-500/15', border: 'border-sky-500/30', text: 'text-sky-400' },
  'theory': { bg: 'bg-amber-500/15', border: 'border-amber-500/30', text: 'text-amber-400' },
  'timeline': { bg: 'bg-violet-500/15', border: 'border-violet-500/30', text: 'text-violet-400' },
};

const strengthIcons: Record<ConnectionStrength, string> = {
  'low': '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 opacity-50"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" /></svg>',
  'medium': '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 opacity-75"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" /></svg>',
  'high': '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 text-primary-light drop-shadow-[0_0_8px_rgba(211,187,255,0.6)]"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" /></svg>',
};

const allTypes = Object.keys(CONNECTION_TYPE_LABELS) as ConnectionType[];
const allStrengths = Object.keys(STRENGTH_LABELS) as ConnectionStrength[];
---

<BaseLayout
  title="Mapa de Conexiones"
  description="Explora las relaciones ocultas y las conexiones narrativas entre eras, miembros, teorías y símbolos del universo BTS."
  canonical="/connections"
>
  <div class="max-w-[1280px] mx-auto px-margin-mobile md:px-margin-desktop py-stack-lg">
    <PageHeader
      tag="Red Narrativa"
      title="Mapa de Conexiones"
      description="Descubre cómo se entrelazan los diferentes elementos del archivo. Filtra por tipo de conexión o por la fuerza de la relación para encontrar patrones ocultos."
    />

    {/* Filtros */}
    <div class="glass-card p-6 mb-12 relative z-20">
      <div class="flex flex-col lg:flex-row gap-8">
        
        {/* Filtro por Tipo */}
        <div class="flex-1">
          <h3 class="label-caps text-on-surface-variant mb-4">Filtrar por elemento</h3>
          <div class="flex flex-wrap gap-2" id="filter-types">
            <button
              type="button"
              class="filter-btn active px-4 py-2 rounded-xl text-sm font-semibold border border-primary bg-primary/20 text-white transition-all"
              data-filter="all"
            >
              Todos
            </button>
            {allTypes.map((type) => (
              <button
                type="button"
                class={`filter-btn px-4 py-2 rounded-xl text-sm font-semibold border border-white/10 bg-white/5 text-on-surface-variant hover:border-white/20 hover:text-white transition-all`}
                data-filter={type}
              >
                {CONNECTION_TYPE_LABELS[type]}
              </button>
            ))}
          </div>
        </div>

        {/* Separador vertical */}
        <div class="hidden lg:block w-px bg-border/50"></div>

        {/* Filtro por Fuerza */}
        <div class="lg:w-64">
          <h3 class="label-caps text-on-surface-variant mb-4">Fuerza de conexión</h3>
          <select 
            id="filter-strength"
            class="w-full bg-surface-container-high border border-white/10 text-on-surface text-sm rounded-xl px-4 py-2.5 focus:outline-none focus:border-primary/50 focus:ring-1 focus:ring-primary/50 appearance-none cursor-pointer"
          >
            <option value="all">Cualquier intensidad</option>
            {allStrengths.map((str) => (
              <option value={str}>{STRENGTH_LABELS[str]}</option>
            ))}
          </select>
        </div>

      </div>
    </div>

    {/* Grid de conexiones */}
    <div id="connections-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {mockConnections.map((conn) => (
        <article
          class="connection-card glass-card p-5 group flex flex-col transition-all duration-300"
          data-source={conn.sourceType}
          data-target={conn.targetType}
          data-strength={conn.strength}
        >
          {/* Cabecera visual de la conexión */}
          <div class="flex items-center justify-between mb-6 pb-4 border-b border-white/5">
            <div class="text-center flex-1">
              <span class={`inline-block px-2.5 py-0.5 rounded-full text-[10px] font-mono font-bold uppercase tracking-widest border ${typeColors[conn.sourceType].border} ${typeColors[conn.sourceType].bg} ${typeColors[conn.sourceType].text} mb-2`}>
                {CONNECTION_TYPE_LABELS[conn.sourceType]}
              </span>
              <p class="text-sm font-semibold text-on-surface line-clamp-1">{conn.sourceTitle}</p>
            </div>

            <div class="px-2 text-on-surface-variant" title={`Fuerza: ${STRENGTH_LABELS[conn.strength]}`}>
              <Fragment set:html={strengthIcons[conn.strength]} />
            </div>

            <div class="text-center flex-1">
              <span class={`inline-block px-2.5 py-0.5 rounded-full text-[10px] font-mono font-bold uppercase tracking-widest border ${typeColors[conn.targetType].border} ${typeColors[conn.targetType].bg} ${typeColors[conn.targetType].text} mb-2`}>
                {CONNECTION_TYPE_LABELS[conn.targetType]}
              </span>
              <p class="text-sm font-semibold text-on-surface line-clamp-1">{conn.targetTitle}</p>
            </div>
          </div>

          {/* Contenido principal */}
          <div class="flex-1">
            <h3 class="text-lg font-serif font-bold text-on-surface mb-3 group-hover:text-primary-light transition-colors">
              {conn.title}
            </h3>
            <p class="text-sm text-on-surface-variant leading-relaxed">
              {conn.description}
            </p>
          </div>

          {/* Tags */}
          {conn.tags && conn.tags.length > 0 && (
            <div class="mt-6 flex flex-wrap gap-1.5 pt-4 border-t border-white/5">
              {conn.tags.map((tag) => (
                <span class="text-xs text-on-surface-variant/70 font-mono before:content-['#']">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </article>
      ))}
    </div>

    {/* Empty State visual para filtros */}
    <div id="empty-state" class="hidden glass-card p-12 text-center mt-8">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-white/5 border border-white/10 mb-6 text-on-surface-variant">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
      </div>
      <h3 class="text-xl font-serif font-bold text-on-surface mb-3">Sin resultados</h3>
      <p class="text-on-surface-variant text-sm max-w-sm mx-auto">
        No se encontraron conexiones que coincidan con los filtros seleccionados. Intenta ampliar tu búsqueda.
      </p>
    </div>

  </div>
</BaseLayout>

<style>
  /* Personalización del select nativo para mantener el estilo dark */
  select {
    background-image: url("data:image/svg+xml;charset=utf-8,%3Csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 24 24' stroke-width='2' stroke='%23ccc3d7'%3E%3Cpath stroke-linecap='round' stroke-linejoin='round' d='M19.5 8.25l-7.5 7.5-7.5-7.5'/%3E%3C/svg%3E");
    background-position: right 1rem center;
    background-repeat: no-repeat;
    background-size: 1em;
  }

  .connection-card {
    animation: fade-in 0.4s ease-out forwards;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Clases activas para los botones de filtro generadas desde JS */
  .filter-btn.active {
    @apply border-primary bg-primary/20 text-white;
  }
</style>

<script>
  const cards = document.querySelectorAll<HTMLElement>('.connection-card');
  const typeBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const strengthSelect = document.getElementById('filter-strength') as HTMLSelectElement;
  const emptyState = document.getElementById('empty-state');

  let currentTypeFilter = 'all';
  let currentStrengthFilter = 'all';

  function filterCards() {
    let visibleCount = 0;

    cards.forEach((card) => {
      const source = card.dataset.source;
      const target = card.dataset.target;
      const strength = card.dataset.strength;

      const matchesType = currentTypeFilter === 'all' || source === currentTypeFilter || target === currentTypeFilter;
      const matchesStrength = currentStrengthFilter === 'all' || strength === currentStrengthFilter;

      if (matchesType && matchesStrength) {
        card.style.display = 'flex';
        // Reiniciar animación sutilmente
        card.style.animation = 'none';
        card.offsetHeight; /* trigger reflow */
        card.style.animation = '';
        visibleCount++;
      } else {
        card.style.display = 'none';
      }
    });

    if (emptyState) {
      emptyState.classList.toggle('hidden', visibleCount > 0);
    }
  }

  // Type filter events
  typeBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      // Update UI state
      typeBtns.forEach(b => {
        b.classList.remove('active', 'border-primary', 'bg-primary/20', 'text-white');
        b.classList.add('border-white/10', 'bg-white/5', 'text-on-surface-variant');
      });
      
      btn.classList.remove('border-white/10', 'bg-white/5', 'text-on-surface-variant');
      btn.classList.add('active', 'border-primary', 'bg-primary/20', 'text-white');

      // Update state and filter
      currentTypeFilter = btn.dataset.filter || 'all';
      filterCards();
    });
  });

  // Strength filter events
  strengthSelect?.addEventListener('change', (e) => {
    currentStrengthFilter = (e.target as HTMLSelectElement).value;
    filterCards();
  });
</script>
