---
interface Props {
  id: string;
  type: 'era' | 'theory' | 'glossary';
  title: string;
  description: string;
  href: string;
}

const { id, type, title, description, href } = Astro.props;
---

<button
  type="button"
  class="favorite-button inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/10 px-4 py-2 text-sm font-semibold text-primary-light transition-colors hover:border-primary-light/60 hover:bg-primary/20"
  data-id={id}
  data-type={type}
  data-title={title}
  data-description={description}
  data-href={href}
  aria-pressed="false"
>
  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
  </svg>
  <span data-favorite-label>Guardar favorito</span>
</button>

<script>
  type FavoriteType = 'era' | 'theory' | 'glossary';

  interface FavoriteItem {
    id: string;
    type: FavoriteType;
    title: string;
    description: string;
    href: string;
  }

  const storageKey = 'bts-lore-favorites';

  const readFavorites = (): FavoriteItem[] => {
    try {
      const stored = window.localStorage.getItem(storageKey);
      return stored ? JSON.parse(stored) : [];
    } catch {
      return [];
    }
  };

  const writeFavorites = (favorites: FavoriteItem[]) => {
    window.localStorage.setItem(storageKey, JSON.stringify(favorites));
    window.dispatchEvent(new CustomEvent('bts-lore-favorites-updated'));
  };

  const getButtonItem = (button: HTMLButtonElement): FavoriteItem => ({
    id: button.dataset.id ?? '',
    type: (button.dataset.type ?? 'theory') as FavoriteType,
    title: button.dataset.title ?? '',
    description: button.dataset.description ?? '',
    href: button.dataset.href ?? '',
  });

  const isSaved = (item: FavoriteItem, favorites: FavoriteItem[]) =>
    favorites.some((favorite) => favorite.id === item.id && favorite.type === item.type);

  const updateButton = (button: HTMLButtonElement) => {
    const item = getButtonItem(button);
    const saved = isSaved(item, readFavorites());
    const label = button.querySelector('[data-favorite-label]');

    button.setAttribute('aria-pressed', String(saved));
    button.classList.toggle('border-secondary-dim/50', saved);
    button.classList.toggle('bg-secondary-dim/15', saved);
    button.classList.toggle('text-secondary-dim', saved);
    button.classList.toggle('border-primary/30', !saved);
    button.classList.toggle('bg-primary/10', !saved);
    button.classList.toggle('text-primary-light', !saved);

    if (label) {
      label.textContent = saved ? 'Favorito guardado' : 'Guardar favorito';
    }
  };

  const syncButtons = () => {
    document.querySelectorAll<HTMLButtonElement>('.favorite-button').forEach(updateButton);
  };

  document.querySelectorAll<HTMLButtonElement>('.favorite-button').forEach((button) => {
    updateButton(button);

    button.addEventListener('click', () => {
      const item = getButtonItem(button);
      const favorites = readFavorites();
      const saved = isSaved(item, favorites);
      const nextFavorites = saved
        ? favorites.filter((favorite) => !(favorite.id === item.id && favorite.type === item.type))
        : [...favorites, item];

      writeFavorites(nextFavorites);
      syncButtons();
    });
  });

  window.addEventListener('storage', syncButtons);
  window.addEventListener('bts-lore-favorites-updated', syncButtons);
</script>
