---
interface Props {
  date: string;
  title: string;
  description: string;
}

const { date, title, description } = Astro.props;
---

<div class="relative pl-10 md:pl-0">
  <div class="md:grid md:grid-cols-5 md:gap-8 items-start">
    <div class="md:col-span-1 md:text-right mb-2 md:mb-0 pt-1">
      <span class="inline-flex rounded-full border border-secondary-dim/30 bg-secondary-dim/10 px-3 py-1.5 label-caps text-secondary-dim shadow-[0_0_18px_rgba(233,195,73,0.12)]">{date}</span>
    </div>
    
    <div class="hidden md:block absolute left-[20%] w-[2px] h-full bg-gradient-to-b from-primary/10 via-primary-light/45 to-secondary-dim/20 -translate-x-1/2 top-0"></div>
    <div class="hidden md:block absolute left-[20%] w-4 h-4 bg-primary rounded-full -translate-x-1/2 top-2 shadow-[0_0_18px_rgba(109,40,217,0.9)] ring-4 ring-primary/15"></div>
    
    <div class="md:hidden absolute left-1 w-[2px] h-full bg-gradient-to-b from-primary/10 via-primary-light/45 to-secondary-dim/20 top-0"></div>
    <div class="md:hidden absolute left-[-3px] w-4 h-4 bg-primary rounded-full top-2 shadow-[0_0_18px_rgba(109,40,217,0.9)] ring-4 ring-primary/15"></div>

    <div class="md:col-span-4 glass-card p-7 md:p-8">
      <h3 class="font-serif text-xl md:text-2xl font-bold text-on-surface mb-3">{title}</h3>
      <p class="text-on-surface-variant font-sans text-sm md:text-base leading-relaxed">{description}</p>
    </div>
  </div>
</div>
