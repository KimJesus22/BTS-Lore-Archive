---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { roadmapItems } from '../data/roadmap';
import { STATUS_LABELS, STATUS_ORDER } from '../types/roadmap';
import type { RoadmapStatus, RoadmapPriority } from '../types/roadmap';

/** Iconos SVG por estado */
const statusIcons: Record<RoadmapStatus, string> = {
  'done': '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>',
  'in-progress': '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M2.985 19.644l3.181-3.182" /></svg>',
  'upcoming': '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>',
  'idea': '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" /></svg>',
};

/** Colores por estado */
const statusColors: Record<RoadmapStatus, { dot: string; header: string; badge: string; border: string; glow: string }> = {
  'done': {
    dot: 'bg-emerald-400',
    header: 'text-emerald-400',
    badge: 'bg-emerald-500/15 text-emerald-400 border-emerald-500/30',
    border: 'border-emerald-500/20',
    glow: 'from-emerald-500/20',
  },
  'in-progress': {
    dot: 'bg-primary-light',
    header: 'text-primary-light',
    badge: 'bg-primary/20 text-primary-light border-primary/30',
    border: 'border-primary/20',
    glow: 'from-primary/20',
  },
  'upcoming': {
    dot: 'bg-secondary-dim',
    header: 'text-secondary-dim',
    badge: 'bg-secondary-dim/15 text-secondary-dim border-secondary-dim/30',
    border: 'border-secondary-dim/20',
    glow: 'from-secondary-dim/20',
  },
  'idea': {
    dot: 'bg-sky-400',
    header: 'text-sky-400',
    badge: 'bg-sky-500/15 text-sky-400 border-sky-500/30',
    border: 'border-sky-500/20',
    glow: 'from-sky-500/20',
  },
};

/** Colores por prioridad */
const priorityColors: Record<RoadmapPriority, string> = {
  'alta': 'bg-red-500/15 text-red-400 border-red-500/25',
  'media': 'bg-amber-500/15 text-amber-400 border-amber-500/25',
  'baja': 'bg-slate-400/15 text-slate-400 border-slate-400/25',
};

const priorityLabels: Record<RoadmapPriority, string> = {
  'alta': 'Alta',
  'media': 'Media',
  'baja': 'Baja',
};

/** Agrupar items por estado */
const grouped = STATUS_ORDER.map((status) => ({
  status,
  label: STATUS_LABELS[status],
  items: roadmapItems.filter((item) => item.status === status),
  colors: statusColors[status],
  icon: statusIcons[status],
}));

const totalDone = roadmapItems.filter((i) => i.status === 'done').length;
const totalAll = roadmapItems.length;
const progressPercent = Math.round((totalDone / totalAll) * 100);
---

<BaseLayout
  title="Roadmap"
  description="Descubre las funcionalidades actuales, en desarrollo y futuras de BTS Lore Archive."
  canonical="/roadmap"
>
  <div class="max-w-[1440px] mx-auto px-margin-mobile md:px-margin-desktop py-stack-lg">
    <PageHeader
      tag="Hoja de ruta"
      title="Roadmap"
      description="El plan de desarrollo de BTS Lore Archive. Descubre qué hemos construido, en qué estamos trabajando y qué viene después."
    />

    <!-- Progress bar -->
    <div id="roadmap-progress" class="glass-card p-6 mb-12 max-w-2xl mx-auto">
      <div class="flex items-center justify-between mb-3">
        <span class="label-caps text-on-surface-variant">Progreso general</span>
        <span class="font-mono text-sm text-primary-light font-bold">{totalDone}/{totalAll} completados</span>
      </div>
      <div class="h-2 rounded-full bg-white/10 overflow-hidden">
        <div
          class="h-full rounded-full bg-gradient-to-r from-primary to-primary-light transition-all duration-700"
          style={`width: ${progressPercent}%`}
        ></div>
      </div>
      <p class="text-xs text-on-surface-variant/70 mt-2 text-right">{progressPercent}%</p>
    </div>

    <!-- Board columns -->
    <div id="roadmap-board" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
      {grouped.map((group) => (
        <section class="flex flex-col" id={`roadmap-col-${group.status}`}>
          {/* Column header */}
          <div class={`flex items-center gap-3 mb-5 pb-3 border-b ${group.colors.border}`}>
            <span class={`flex items-center justify-center w-7 h-7 rounded-lg ${group.colors.badge}`}>
              <Fragment set:html={group.icon} />
            </span>
            <h2 class={`text-lg font-serif font-bold ${group.colors.header}`}>{group.label}</h2>
            <span class="ml-auto font-mono text-xs text-on-surface-variant bg-white/5 rounded-full px-2 py-0.5">
              {group.items.length}
            </span>
          </div>

          {/* Cards */}
          <div class="space-y-4 flex-1">
            {group.items.map((item) => (
              <article
                class="roadmap-card glass-card p-5 group relative overflow-hidden"
                id={`roadmap-item-${item.id}`}
              >
                {/* Top glow line */}
                <div class={`absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r ${group.colors.glow} to-transparent opacity-60`}></div>

                {/* Badges row */}
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class={`inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[11px] font-mono font-bold uppercase tracking-wider border ${group.colors.badge}`}>
                    <span class={`w-1.5 h-1.5 rounded-full ${group.colors.dot}`}></span>
                    {group.label}
                  </span>
                  <span class={`inline-flex px-2.5 py-0.5 rounded-full text-[11px] font-mono font-bold uppercase tracking-wider border ${priorityColors[item.priority]}`}>
                    {priorityLabels[item.priority]}
                  </span>
                </div>

                {/* Content */}
                <h3 class="text-base font-serif font-bold text-on-surface mb-2 group-hover:text-primary-light transition-colors">
                  {item.title}
                </h3>
                <p class="text-sm text-on-surface-variant leading-relaxed">
                  {item.description}
                </p>

                {/* Estimated date */}
                {item.estimatedDate && (
                  <div class="mt-3 flex items-center gap-1.5 text-xs text-on-surface-variant/60">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                    </svg>
                    <span>{item.estimatedDate}</span>
                  </div>
                )}
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>

    <!-- Footer note -->
    <div class="mt-16 text-center">
      <p class="text-sm text-on-surface-variant/60 max-w-lg mx-auto">
        Este roadmap es una guía general. Las prioridades y fechas pueden cambiar según las necesidades del proyecto y los aportes de la comunidad.
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  .roadmap-card {
    animation: roadmap-fade-in 0.4s ease-out both;
  }

  @keyframes roadmap-fade-in {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Stagger animation per card */
  .roadmap-card:nth-child(1) { animation-delay: 0.05s; }
  .roadmap-card:nth-child(2) { animation-delay: 0.1s; }
  .roadmap-card:nth-child(3) { animation-delay: 0.15s; }
  .roadmap-card:nth-child(4) { animation-delay: 0.2s; }
  .roadmap-card:nth-child(5) { animation-delay: 0.25s; }
  .roadmap-card:nth-child(6) { animation-delay: 0.3s; }
</style>
